# Medical RAG Application Environment Configuration
# Copy this file to .env and customize as needed

# ===== Backend Configuration =====
# Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
# CUDA_DEVICE_ORDER=PCI_BUS_ID

# Index Configuration
DEFAULT_INDEX_NAME=medcorp_medembed
INDEX_BASE_DIR=../../indexes

# Model Configuration
DEFAULT_EMBED_MODEL=abhinand/MedEmbed-large-v0.1
DEFAULT_LLM_MODEL=thewindmom/llama3-med42-8b
DEFAULT_TOKENIZER=deepseek-ai/DeepSeek-R1

# Server Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# Performance Configuration
MAX_WORKERS=4
BATCH_SIZE=1
MAX_EVIDENCE_TOKENS=1200

# ===== Docker Configuration =====
# Compose project name
COMPOSE_PROJECT_NAME=medrag

# Volume paths (adjust for your system)
INDEXES_PATH=../../indexes
MODELS_PATH=./models

# ===== Optional: Redis Configuration =====
# REDIS_URL=redis://localhost:6379
# CACHE_TTL=3600

# ===== Optional: Logging Configuration =====
LOG_LEVEL=INFO
# LOG_FILE=logs/medrag.log

# ===== Optional: Security Configuration =====
# API_KEY=your-secret-api-key-here
# ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# ===== Development Configuration =====
DEBUG=false
RELOAD=false
